# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false

# Binance personal account automation (first stage defaults are non-live).
# Create a Binance API key with read/trade permissions only; do not enable withdrawals.
BINANCE_API_KEY=
BINANCE_API_SECRET=
TRADINGAGENTS_CRYPTO_BINANCE_TESTNET=true
#TRADINGAGENTS_CRYPTO_BINANCE_BASE_URL=https://testnet.binance.vision
TRADINGAGENTS_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT
TRADINGAGENTS_CRYPTO_INTERVAL=15m
TRADINGAGENTS_CRYPTO_LOOKBACK_LIMIT=120
TRADINGAGENTS_CRYPTO_ACCOUNT_EQUITY_USDT=10000
TRADINGAGENTS_CRYPTO_RISK_PER_TRADE_PCT=0.005
TRADINGAGENTS_CRYPTO_MAX_POSITION_PCT=0.10
TRADINGAGENTS_CRYPTO_DAILY_LOSS_LIMIT_PCT=0.03
TRADINGAGENTS_CRYPTO_MIN_CONFIDENCE=0.62
TRADINGAGENTS_CRYPTO_AI_ROUTER=tradingagents
# Future target: set to hermes after the Hermes adapter/API contract is added.
#TRADINGAGENTS_CRYPTO_AI_ROUTER=hermes
#TRADINGAGENTS_CRYPTO_AI_MODEL=
TRADINGAGENTS_CRYPTO_AI_DECISION_POLICY=advisory_only
TRADINGAGENTS_CRYPTO_AI_AGENT_STYLE=tradingagents_crypto
#TRADINGAGENTS_CRYPTO_HERMES_BASE_URL=http://127.0.0.1:8000/v1
#TRADINGAGENTS_CRYPTO_HERMES_API_KEY=
#TRADINGAGENTS_CRYPTO_HERMES_TIMEOUT_SECONDS=45
TRADINGAGENTS_CRYPTO_EXECUTION_MODE=analysis
TRADINGAGENTS_CRYPTO_ENABLE_LIVE_ORDERS=false
TRADINGAGENTS_CRYPTO_LIVE_CONFIRM_PHRASE=I_UNDERSTAND_THIS_PLACES_REAL_BINANCE_ORDERS
#TRADINGAGENTS_CRYPTO_EMERGENCY_STOP_FILE=C:\tradingagents-stop.txt
